{
  "name": "spl-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/dev.js",
    "dev:vite": "vite",
    "build": "vite build",
    "build:android": "vite build --mode android",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "android:sync": "node scripts/android-build.cjs --sync-only",
    "android:open": "npx cap open android",
    "android:apk": "node scripts/android-build.cjs assembleDebug",
    "android:release:setup": "node scripts/android-setup-release.cjs",
    "android:release:apk": "node scripts/android-build.cjs assembleRelease",
    "android:release:aab": "node scripts/android-build.cjs bundleRelease",
    "android:release:all": "npm run android:release:setup && node scripts/android-build.cjs assembleRelease bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@imgly/background-removal-node": "^1.4.5",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.0"
