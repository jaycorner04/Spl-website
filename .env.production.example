NODE_ENV=production
PORT=4000
HOST=0.0.0.0
DB_SERVER=your-sql-host
DB_PORT=1433
DB_NAME=SPLSqlServer
DB_BOOTSTRAP_DATABASE=master
DB_USER=your_sql_login
DB_PASSWORD=your_sql_password
SPL_AUTH_SECRET=replace-with-a-long-random-secret
CORS_ALLOWED_ORIGINS=same-origin
RATE_LIMIT_ENABLED=true
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false
