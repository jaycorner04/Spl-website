{
  "name": "spl",
  "private": true,
  "scripts": {
    "db:health": "node scripts/db-health.js",
    "db:migrate": "node scripts/db-migrate.js",
    "db:backup": "node scripts/db-backup.js",
    "db:restore": "node scripts/db-restore.js",
    "db:sync-seed": "node scripts/sync-seed-data.js",
    "env:generate:production": "node scripts/generate-production-env.js",
    "validate:env": "node scripts/env-check.js",
    "monitor:health": "node scripts/monitor-health.js",
    "lint:frontend": "npm run lint --prefix spl-frontend",
    "frontend": "npm run dev --prefix spl-frontend",
    "dev": "node scripts/dev.js",
    "build:frontend": "npm run build --prefix spl-frontend",
    "qa:frontend-routes": "node scripts/frontend-route-smoke.js",
    "qa:server-spa": "node scripts/server-spa-smoke.js",
    "qa:deployed": "node scripts/deployed-smoke.js",
    "qa:roles": "node scripts/dashboard-role-smoke.js",
    "qa:full": "npm run release:check && npm run qa:roles",
    "release:check": "npm run lint:frontend && npm run db:migrate && npm test && npm run build:frontend && npm run qa:frontend-routes && npm run qa:server-spa",
    "test:smoke": "node --test scripts/dashboard-services.test.js",
    "test:integration": "node --test scripts/api-integration.test.js",
    "test": "npm run test:smoke && npm run test:integration",
    "api": "node scripts/run-python-api.js",
    "start": "node scripts/run-python-api.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "mssql": "^12.2.1"
  }
}
